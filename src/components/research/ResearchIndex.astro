---
import type { CollectionEntry } from "astro:content";
import { formatShortDate } from "@/utils/romanNumerals";
import { getResearchProjects } from "@/lib/researchProjects";

interface Props {
  entries: CollectionEntry<"research">[];
}

const { entries } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const projects = getResearchProjects(entries);
---

<section class="ri">
  <header class="ri__head">
    <div class="shell ri__head-inner">
      <div class="meta">research notes</div>
      <h1 class="ri__title">
        Research Notes <span class="ri__count mono">[{entries.length}]</span>
      </h1>
      <p class="ri__lede">
        Applied technical investigations grouped by research project. Open a project
        to read only the notes in that series.
      </p>
    </div>
    <hr class="hairline" />
  </header>

  <div class="shell ri__body">
    {projects.length === 0 ? (
      <p class="ri__empty mono">nothing filed yet</p>
    ) : (
      <ol class="ri__projects">
        {projects.map((project) => (
          <li class="ri__project">
            <a href={`${base}/research/${project.slug}/`} class="ri__project-link">
              <div class="ri__project-main">
                <div class="ri__kicker">
                  {project.latest.data.featured && <span class="ri__featured">featured</span>}
                  <span class="mono">{project.entries.length} note{project.entries.length === 1 ? "" : "s"}</span>
                  <time class="mono">updated {formatShortDate(project.latest.data.date)}</time>
                </div>
                <h2 class="ri__project-title">{project.title}</h2>
                <p class="ri__summary">{project.latest.data.summary}</p>
              </div>
              <div class="ri__meta">
                {project.tags.map((tag) => (
                  <span class="ri__tag">{tag}</span>
                ))}
              </div>
            </a>
          </li>
        ))}
      </ol>
    )}
  </div>
</section>

<style>
  .ri {
    padding-block: 2.5rem 4rem;
  }
  .ri__head-inner {
    padding-bottom: 1.5rem;
  }
  .ri__title {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 144, "wght" 320, "SOFT" 10;
    font-size: clamp(2.6rem, 7vw, 5.25rem);
    line-height: 0.95;
    margin: 0.4rem 0 0.85rem;
  }
  .ri__count {
    color: var(--color-muted);
    font-size: 0.45em;
    vertical-align: 0.7em;
    margin-left: 0.4em;
  }
  .ri__lede {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.5;
    max-width: 54ch;
    margin: 0;
  }
  .ri__body {
    padding-block: 3rem 1rem;
  }
  .ri__projects {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 2px solid var(--color-ink);
  }
  .ri__project {
    border-bottom: 1px solid var(--color-hairline);
  }
  .ri__project-link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 15rem;
    gap: 2rem;
    align-items: start;
    padding-block: 1.25rem;
  }
  .ri__project-link:hover .ri__project-title {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .ri__kicker {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    color: var(--color-muted);
    font-size: 0.72rem;
    margin-bottom: 0.45rem;
  }
  .ri__featured,
  .ri__tag {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.62rem;
    border: 1px solid var(--color-hairline);
    color: var(--color-muted);
    padding: 0.12rem 0.45rem;
  }
  .ri__featured {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }
  .ri__project-title {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 96, "wght" 540;
    font-size: clamp(1.5rem, 2.8vw, 2.15rem);
    line-height: 1.16;
    margin: 0;
  }
  .ri__summary {
    margin: 0.65rem 0 0;
    max-width: 64ch;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .ri__meta {
    display: flex;
    justify-content: flex-end;
    align-content: flex-start;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding-top: 0.25rem;
  }
  .ri__empty {
    color: var(--color-muted);
    border-top: 2px solid var(--color-ink);
    margin: 0;
    padding-top: 1rem;
    font-size: 0.75rem;
  }

  @media (max-width: 56rem) {
    .ri__project-link {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .ri__meta {
      justify-content: flex-start;
    }
  }
</style>
