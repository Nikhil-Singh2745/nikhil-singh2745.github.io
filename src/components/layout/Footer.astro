---
import { toRoman } from "@/utils/romanNumerals";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = new Date().getUTCFullYear();
const yearRoman = toRoman(year);
---

<footer class="footer">
  <hr class="hairline" />
  <div class="shell footer__inner">
    <div class="footer__col">
      <div class="footer__label">on the record</div>
      <p class="footer__statement">
        a low-level notebook. nothing here is investment
        advice, employment commentary, or affiliated with any organization.
      </p>
    </div>

    <div class="footer__col footer__col--links">
      <div class="footer__label">elsewhere</div>
      <ul>
        <li><a href={`${base}/colophon/`}>colophon</a></li>
        <li>
          <button type="button" data-konami-help class="footer__btn">
            keyboard shortcuts (?)
          </button>
        </li>
      </ul>
    </div>

    <div class="footer__col footer__col--mark">
      <div class="footer__mark">§</div>
      <div class="footer__copy">coredump · {yearRoman} · all rights reserved by no one</div>
    </div>
  </div>
</footer>

<script>
  // toggle the shortcut sheet when the footer button is clicked
  document.addEventListener("click", (e) => {
    const t = e.target as HTMLElement;
    if (!t.closest("[data-konami-help]")) return;
    const sheet = document.getElementById("kbd-sheet");
    if (!sheet) return;
    const open = sheet.getAttribute("data-open") === "true";
    sheet.setAttribute("data-open", String(!open));
  });
</script>

<style>
  .footer {
    margin-top: 6rem;
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 2.5rem;
    padding-block: 2.5rem 4rem;
  }
  .footer__label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-muted);
    margin-bottom: 0.85rem;
  }
  .footer__statement {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink);
    max-width: 36ch;
    margin: 0;
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }
  .footer__col li a:hover,
  .footer__btn:hover {
    border-bottom: 1px solid var(--color-ink);
  }
  .footer__btn {
    font: inherit;
    background: none;
    border: 0;
    padding: 0;
    color: inherit;
    cursor: pointer;
  }
  .footer__col--mark {
    text-align: right;
  }
  .footer__mark {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 144, "wght" 300;
    font-size: 6rem;
    line-height: 1;
    color: var(--color-muted);
  }
  .footer__copy {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
  }

  @media (max-width: 56rem) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer__col--mark {
      text-align: left;
    }
    .footer__mark {
      font-size: 4rem;
    }
  }
</style>
