---
// SVG <defs> with reusable B&W hatch / dot / line patterns.
// Mount this once near the top of the page and reference patterns by id.
---

<svg
  width="0"
  height="0"
  aria-hidden="true"
  style="position:absolute;width:0;height:0;overflow:hidden;"
>
  <defs>
    <pattern
      id="hatch-diag"
      patternUnits="userSpaceOnUse"
      width="6"
      height="6"
      patternTransform="rotate(45)"
    >
      <line x1="0" y1="0" x2="0" y2="6" stroke="currentColor" stroke-width="1" />
    </pattern>

    <pattern id="hatch-dot" patternUnits="userSpaceOnUse" width="10" height="10">
      <circle cx="2" cy="2" r="0.9" fill="currentColor" />
    </pattern>

    <pattern id="hatch-grid" patternUnits="userSpaceOnUse" width="14" height="14">
      <path d="M14 0 H0 V14" fill="none" stroke="currentColor" stroke-width="0.5" />
    </pattern>

    <pattern id="hatch-lines" patternUnits="userSpaceOnUse" width="24" height="6">
      <line x1="0" y1="5.5" x2="24" y2="5.5" stroke="currentColor" stroke-width="0.5" />
    </pattern>

    <pattern id="hatch-halftone" patternUnits="userSpaceOnUse" width="8" height="8">
      <circle cx="2" cy="2" r="1.4" fill="currentColor" />
      <circle cx="6" cy="6" r="0.6" fill="currentColor" />
    </pattern>
  </defs>
</svg>
