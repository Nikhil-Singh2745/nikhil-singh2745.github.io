---
import { formatEntryDate, formatIso } from "@/utils/romanNumerals";

interface Props {
  date: Date;
  class?: string;
}
const { date, class: cls = "" } = Astro.props;
const pretty = formatEntryDate(date);
const iso = formatIso(date);
---

<time datetime={iso} class={`mono ${cls}`}>{pretty}</time>
