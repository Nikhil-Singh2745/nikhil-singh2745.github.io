---
import { codeToHtml } from "shiki";
import { blackAndWhiteTheme } from "@/lib/shiki-bw";

interface Props {
  code: string;
  lang?: string;
  caption?: string;
}
const { code, lang = "txt", caption } = Astro.props;

const html = await codeToHtml(code.trimEnd(), {
  lang,
  theme: blackAndWhiteTheme,
});
---
<figure class="codeblock">
  <Fragment set:html={html} />
  {caption && <figcaption class="codeblock__cap">{caption}</figcaption>}
</figure>

<style>
  .codeblock {
    margin: 1.5rem 0;
  }
  .codeblock :global(pre) {
    background: var(--color-inv-paper);
    color: var(--color-inv-ink);
    padding: 1.5rem 1.5rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.55;
    border-top: 1px solid var(--color-ink);
    border-bottom: 1px solid var(--color-ink);
  }
  .codeblock__cap {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: 0.65rem;
    text-align: center;
  }
</style>
