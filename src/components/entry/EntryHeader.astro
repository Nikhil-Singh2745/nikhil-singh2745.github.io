---
import { formatEntryDate, formatIso } from "@/utils/romanNumerals";

interface Props {
  number: number;
  title: string;
  subtitle?: string;
  date: Date;
  tags: string[];
  readingMinutes: number;
  backHref?: string;
  backLabel?: string;
}

const {
  number,
  title,
  subtitle,
  date,
  tags,
  readingMinutes,
  backHref,
  backLabel = "all writing",
} = Astro.props;
const num = String(number).padStart(3, "0");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const resolvedBackHref = backHref ?? `${base}/writing/`;
---

<header class="eh">
  <div class="shell">
    <div class="eh__bar">
      <a href={resolvedBackHref} class="eh__back mono">← {backLabel}</a>
      <div class="eh__bar-meta mono">
        № {num} · <time datetime={formatIso(date)}>{formatEntryDate(date)}</time> ·
        {readingMinutes} min
      </div>
    </div>
    <hr class="hairline" />

    <div class="eh__title-wrap">
      <div class="eh__shoulder">
        {tags.map((t) => (
          <span class="eh__tag">{t}</span>
        ))}
      </div>
      <h1 class="eh__title">{title}</h1>
      {subtitle && <p class="eh__subtitle">{subtitle}</p>}
    </div>

    <hr class="hairline-thick" />
  </div>
</header>

<style>
  .eh {
    padding-block: 1.5rem 0;
  }
  .eh__bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 0.85rem;
    color: var(--color-muted);
    font-size: 0.75rem;
  }
  .eh__back {
    color: var(--color-muted);
    transition: color 180ms;
  }
  .eh__back:hover {
    color: var(--color-ink);
  }
  .eh__title-wrap {
    padding-block: 2.5rem 2rem;
  }
  .eh__shoulder {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .eh__tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-muted);
    border: 1px solid var(--color-hairline);
    padding: 0.18rem 0.55rem;
  }
  .eh__title {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 144, "wght" 360, "SOFT" 0;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.96;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--color-ink);
    max-width: 22ch;
  }
  .eh__subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-variation-settings: "opsz" 96, "wght" 380;
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    color: var(--color-muted);
    margin: 1.25rem 0 0;
    max-width: 50ch;
    line-height: 1.4;
  }

  @media (max-width: 48rem) {
    .eh__bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }
  }
</style>
