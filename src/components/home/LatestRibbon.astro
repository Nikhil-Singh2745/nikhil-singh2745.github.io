---
import type { CollectionEntry } from "astro:content";
import { formatEntryDate } from "@/utils/romanNumerals";
import { writingSections } from "@/lib/writingSections";

interface Props {
  entries: CollectionEntry<"dumps">[];
}

const { entries } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const recommendations = entries.map((entry) => ({
  title: entry.data.title,
  subtitle: entry.data.subtitle ?? "",
  summary: entry.data.summary,
  date: formatEntryDate(entry.data.date),
  section: writingSections[entry.data.section].label,
  href: `${base}/writing/${entry.id}/`,
}));
const fallback = recommendations[0] ?? null;
---

<section class="ribbon" data-random-recommendation>
  <div class="shell">
    <header class="ribbon__head">
      <div>
        <div class="ribbon__label meta">random writing</div>
        <p class="ribbon__hint">one entry to read next. refresh for another.</p>
      </div>
      <a class="ribbon__all mono" href={`${base}/writing/`}>browse shelves -></a>
    </header>
    <hr class="hairline" />

    {fallback ? (
      <article class="ribbon__card">
        <a href={fallback.href} class="ribbon__link" data-rec-link>
          <span class="ribbon__num mono">pick</span>
          <div class="ribbon__body">
            <h3 class="ribbon__title" data-rec-title>{fallback.title}</h3>
            <p
              class={`ribbon__sub ${fallback.subtitle ? "" : "ribbon__sub--empty"}`}
              data-rec-subtitle
            >
              {fallback.subtitle}
            </p>
            <p class="ribbon__summary" data-rec-summary>{fallback.summary}</p>
          </div>
          <div class="ribbon__meta">
            <time class="mono" data-rec-date>{fallback.date}</time>
            <span class="ribbon__tag" data-rec-section>{fallback.section}</span>
          </div>
        </a>
      </article>
    ) : (
      <p class="ribbon__empty mono">nothing filed yet</p>
    )}
  </div>
</section>

<script define:vars={{ recommendations }}>
  const card = document.querySelector("[data-random-recommendation]");

  if (card && recommendations.length > 0) {
    const pick = recommendations[Math.floor(Math.random() * recommendations.length)];
    const link = card.querySelector("[data-rec-link]");
    const title = card.querySelector("[data-rec-title]");
    const subtitle = card.querySelector("[data-rec-subtitle]");
    const summary = card.querySelector("[data-rec-summary]");
    const date = card.querySelector("[data-rec-date]");
    const section = card.querySelector("[data-rec-section]");

    if (link) link.setAttribute("href", pick.href);
    if (title) title.textContent = pick.title;
    if (subtitle) {
      subtitle.textContent = pick.subtitle;
      subtitle.classList.toggle("ribbon__sub--empty", pick.subtitle.length === 0);
    }
    if (summary) summary.textContent = pick.summary;
    if (date) date.textContent = pick.date;
    if (section) section.textContent = pick.section;
  }
</script>

<style>
  .ribbon {
    padding-block: 1rem 4rem;
  }
  .ribbon__head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
    padding-block: 1rem 0.75rem;
  }
  .ribbon__hint {
    font-family: var(--font-serif);
    color: var(--color-muted);
    font-size: 0.95rem;
    font-style: italic;
    margin: 0.35rem 0 0;
  }
  .ribbon__all {
    color: var(--color-muted);
    transition: color 180ms var(--ease-out-expo);
    white-space: nowrap;
  }
  .ribbon__all:hover {
    color: var(--color-ink);
  }
  .ribbon__card {
    border-bottom: 1px solid var(--color-hairline);
  }
  .ribbon__link {
    display: grid;
    grid-template-columns: 4rem 1fr 14rem;
    gap: 1.5rem;
    padding-block: 1.5rem;
    align-items: start;
  }
  .ribbon__num {
    color: var(--color-muted);
    font-size: 0.78rem;
    padding-top: 0.4rem;
  }
  .ribbon__title {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 96, "wght" 540;
    font-size: clamp(1.35rem, 2.4vw, 1.85rem);
    line-height: 1.16;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-ink);
  }
  .ribbon__sub {
    margin: 0.35rem 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-muted);
  }
  .ribbon__sub--empty {
    display: none;
  }
  .ribbon__summary {
    margin: 0.65rem 0 0;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-ink);
    max-width: 56ch;
  }
  .ribbon__meta {
    text-align: right;
    display: grid;
    gap: 0.55rem;
    justify-items: end;
    align-content: start;
    padding-top: 0.4rem;
  }
  .ribbon__tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-hairline);
    padding: 0.1rem 0.45rem;
  }
  .ribbon__link:hover .ribbon__title {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }
  .ribbon__empty {
    color: var(--color-muted);
    padding-block: 1.5rem;
  }

  @media (max-width: 56rem) {
    .ribbon__head,
    .ribbon__link {
      grid-template-columns: 1fr;
    }
    .ribbon__head {
      display: grid;
    }
    .ribbon__link {
      gap: 1rem;
    }
    .ribbon__meta {
      text-align: left;
      justify-items: start;
    }
  }
</style>
