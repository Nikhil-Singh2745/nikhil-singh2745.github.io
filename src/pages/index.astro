---
import PageLayout from "@/layouts/PageLayout.astro";
import Cover from "@/components/home/Cover.astro";
import Manifest from "@/components/home/Manifest.astro";
import LatestRibbon from "@/components/home/LatestRibbon.astro";
import { getCollection } from "astro:content";

const dumps = (await getCollection("dumps", ({ data }) => !data.draft)).sort(
  (a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return a.id.localeCompare(b.id);
  }
);

const recent = dumps;
const issueNumber = dumps.length;
const asOf = dumps[0]?.data.date ?? new Date();
---

<PageLayout title="coredump: low-level notes" pageKind="cover">
  <Cover issueNumber={Math.max(1, issueNumber)} asOfDate={asOf} />
  <Manifest />
  <LatestRibbon entries={recent} />
</PageLayout>
