---
import PageLayout from "@/layouts/PageLayout.astro";
import Corkboard from "@/components/notes/Corkboard.astro";
import { getCollection } from "astro:content";

const dumps = (await getCollection("dumps", ({ data }) => !data.draft)).sort(
  (a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.date.getTime() - a.data.date.getTime();
  }
);
---

<PageLayout title="all dumps - coredump" pageKind="dumps">
  <Corkboard entries={dumps} />
</PageLayout>
