---
import PageLayout from "@/layouts/PageLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<PageLayout title="404 - coredump" pageKind="404">
  <section class="nf">
    <div class="shell nf__shell">
      <pre class="nf__art">  segmentation fault
       (core dumped)
</pre>
      <div class="nf__big">404</div>
      <p class="nf__msg">
        that page is not in the symbol table.
      </p>
      <div class="nf__links">
        <a href={`${base}/`}>back to the cover</a>
        <span>·</span>
        <a href={`${base}/dumps/`}>or browse the corkboard</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .nf {
    padding-block: 6rem 8rem;
  }
  .nf__shell {
    text-align: center;
    max-width: 36rem;
    margin-inline: auto;
  }
  .nf__art {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0;
    white-space: pre;
  }
  .nf__big {
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 144, "wght" 220, "SOFT" 0;
    font-size: clamp(8rem, 22vw, 14rem);
    line-height: 0.85;
    color: var(--color-ink);
    margin: 1rem 0 0;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.04em;
  }
  .nf__msg {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-muted);
    margin: 1.5rem 0 2rem;
  }
  .nf__links {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
    display: flex;
    justify-content: center;
    gap: 0.8rem;
  }
  .nf__links a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-ink);
  }
  .nf__links a:hover {
    background: var(--color-ink);
    color: var(--color-paper);
  }
</style>
