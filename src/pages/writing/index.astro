---
import PageLayout from "@/layouts/PageLayout.astro";
import WritingIndex from "@/components/writing/WritingIndex.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("dumps", ({ data }) => !data.draft)).sort(
  (a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.date.getTime() - a.data.date.getTime();
  },
);
---

<PageLayout title="all writing - coredump" pageKind="writing">
  <WritingIndex entries={entries} />
</PageLayout>
