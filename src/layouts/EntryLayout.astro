---
import PageLayout from "./PageLayout.astro";
import EntryHeader from "@/components/entry/EntryHeader.astro";
import EntryFooter from "@/components/entry/EntryFooter.astro";
import ReadingProgress from "@/components/entry/ReadingProgress.astro";
import "@/styles/prose.css";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"dumps">;
  index: number;
  readingMinutes: number;
  prev: CollectionEntry<"dumps"> | null;
  next: CollectionEntry<"dumps"> | null;
}

const { entry, index, readingMinutes, prev, next } = Astro.props;
const { title, subtitle, date, tags, summary, sourceUrl, sourceLabel } = entry.data;
---

<PageLayout title={`${title} - coredump`} description={summary} pageKind="entry">
  <ReadingProgress />
  <article class="entry">
    <EntryHeader
      number={index}
      title={title}
      subtitle={subtitle}
      date={date}
      tags={tags}
      readingMinutes={readingMinutes}
    />

    <div class="entry__body">
      {
        sourceUrl && (
          <div class="entry__github-banner">
            <span class="meta entry__github-label">// Source</span>
            <a
              href={sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="entry__github-link mono"
            >
              <svg
                class="entry__github-icon"
                viewBox="0 0 16 16"
                width="14"
                height="14"
                fill="currentColor"
              >
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
              </svg>
              {sourceLabel ?? "source"} →
            </a>
          </div>
        )
      }
      <div class="prose">
        <slot />
      </div>
    </div>

    <EntryFooter prev={prev} next={next} />
  </article>
</PageLayout>

<style>
  .entry__body {
    padding-block: 3rem 1rem;
  }
  .entry__github-banner {
    max-width: var(--max-reading);
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid var(--color-hairline);
    background: var(--color-paper-warm);
    padding: 0.75rem 1rem;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 48rem) {
    .entry__github-banner {
      margin-inline: var(--gutter);
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
  .entry__github-label {
    color: var(--color-muted);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
  }
  .entry__github-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-ink);
    border: 1px solid var(--color-hairline);
    padding: 0.3rem 0.6rem;
    background: var(--color-paper);
    transition: all 180ms var(--ease-out-expo);
  }
  .entry__github-link:hover {
    border-color: var(--color-ink);
    transform: translateY(-1px);
    box-shadow: 2px 2px 0 0 var(--color-ink);
  }
  .entry__github-icon {
    display: inline-block;
    vertical-align: middle;
  }
</style>
