---
import "@/styles/global.css";
import Masthead from "@/components/layout/Masthead.astro";
import Footer from "@/components/layout/Footer.astro";
import Hatch from "@/components/ui/Hatch.astro";
import ShortcutSheet from "@/components/ui/ShortcutSheet.astro";
import InspectMode from "@/components/ui/InspectMode.astro";
import KonamiPhosphor from "@/components/ui/KonamiPhosphor.astro";

interface Props {
  title: string;
  description?: string;
  pageKind?: "cover" | "writing" | "dumps" | "entry" | "research" | "colophon" | "404";
}

const {
  title,
  description = "coredump: low-level notes. systems, C++, infra, performance.",
  pageKind = "cover",
} = Astro.props;

const site = Astro.site?.toString() ?? "";
const canonical = new URL(Astro.url.pathname, site || "https://coredump.example").toString();
---

<!doctype html>
<html lang="en" data-page={pageKind}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light only" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
  </head>
  <body>
    <Hatch />
    <div class="contact-banner">
      <div class="shell contact-banner__inner">
        <span class="meta contact-banner__label">Correspondence</span>
        <a href="mailto:niksinghsnr2745@gmail.com" class="contact-banner__link mono">
          // contact me · niksinghsnr2745@gmail.com
        </a>
      </div>
    </div>
    <Masthead />
    <main>
      <slot />
    </main>
    <Footer />
    <ShortcutSheet />
    <InspectMode />
    <KonamiPhosphor />
  </body>
  <style>
    .contact-banner {
      background: var(--color-paper-warm);
      border-bottom: 1px solid var(--color-hairline);
      padding-block: 0.5rem;
      font-size: 0.75rem;
    }
    .contact-banner__inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .contact-banner__label {
      color: var(--color-muted);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
    }
    .contact-banner__link {
      color: var(--color-ink);
      text-decoration: none;
      transition: color 180ms var(--ease-out-expo);
      font-size: 0.8rem;
    }
    .contact-banner__link:hover {
      color: var(--color-muted);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    @media (max-width: 48rem) {
      .contact-banner__inner {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
      }
    }
  </style>
</html>
